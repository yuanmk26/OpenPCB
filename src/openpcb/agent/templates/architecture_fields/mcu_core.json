{
  "template_id": "architecture_fields_mcu_core",
  "version": "v2",
  "board_class": "mcu_core",
  "title": "MCU 单片机核心板信息模型",
  "description": "用于描述 MCU 核心板的架构关键信息，强调板卡事实与设计约束，而不是问题脚本。",
  "required_fields": [
    "board_type",
    "use_case",
    "main_controller_type",
    "main_controller_part",
    "power.input_sources",
    "interfaces",
    "clock",
    "reset_boot",
    "assembly_mode",
    "reference_design_available"
  ],
  "field_groups": [
    {
      "key": "board_identity",
      "label": "板卡定位",
      "description": "定义这块板是什么板，以及它解决什么任务。",
      "fields": [
        {
          "key": "board_type",
          "label": "板卡类型",
          "priority": "P0",
          "description": "板卡在系统中的角色定位，应明确它是 MCU 核心板而非完整主控系统。",
          "examples": ["MCU 核心板", "STM32 控制核心板"],
          "options": ["MCU 核心板", "MCU 最小系统板", "MCU 控制主板"],
          "custom_hint": "请明确板卡定位，例如“STM32 控制核心板”。",
          "validation": {"min_length": 2}
        },
        {
          "key": "use_case",
          "label": "使用场景",
          "priority": "P0",
          "description": "核心板面向的业务场景或控制任务，用于约束接口、算力和实时性。",
          "examples": ["机器人底盘控制", "通用设备控制器"],
          "options": ["通用控制", "电机/运动控制", "采集与通信"],
          "custom_hint": "请描述核心业务场景，例如“机器人底盘控制”。",
          "validation": {"min_length": 2}
        }
      ]
    },
    {
      "key": "controller_selection",
      "label": "主控选型",
      "description": "定义 MCU 系列及具体器件。",
      "fields": [
        {
          "key": "main_controller_type",
          "label": "主控系列",
          "priority": "P0",
          "description": "主控芯片所属系列，用于确定生态、工具链和常见外设能力。",
          "examples": ["STM32", "ESP32", "NXP LPC"],
          "options": ["STM32", "ESP32", "NXP LPC"],
          "custom_hint": "请填写主控系列名称，例如“STM32”。",
          "validation": {"min_length": 2}
        },
        {
          "key": "main_controller_part",
          "label": "主控型号",
          "priority": "P0",
          "description": "主控芯片的完整料号，应能唯一确定封装、Flash 和引脚资源。",
          "examples": ["STM32F103C8T6", "STM32H743VIT6"],
          "options": ["STM32F103", "STM32F407", "STM32H743"],
          "custom_hint": "请填写完整型号，例如“STM32F103C8T6”。",
          "validation": {"min_length": 3}
        }
      ]
    },
    {
      "key": "power_and_io",
      "label": "供电与接口",
      "description": "定义核心板外部连接方式和基础供电条件。",
      "fields": [
        {
          "key": "power.input_sources",
          "label": "输入电源",
          "priority": "P0",
          "description": "板卡可接受的输入电源来源与电压范围。",
          "examples": ["USB 5V", "USB 5V + 12V 适配器"],
          "options": ["USB 5V", "12V 适配器", "电池供电"],
          "custom_hint": "请说明电压与来源，例如“USB 5V + 12V 适配器”。",
          "validation": {"min_length": 2}
        },
        {
          "key": "interfaces",
          "label": "关键接口",
          "priority": "P0",
          "description": "设计必须具备的对外通信或控制接口集合。",
          "examples": ["USB, UART, CAN, I2C", "CAN, SPI, UART"],
          "options": ["USB + UART", "CAN + UART", "SPI + I2C"],
          "custom_hint": "请列出接口组合，例如“USB, UART, CAN, I2C”。",
          "validation": {"min_length": 2}
        }
      ]
    },
    {
      "key": "implementation_constraints",
      "label": "实现约束",
      "description": "定义时钟、启动、装配与可复用性等实现条件。",
      "fields": [
        {
          "key": "clock",
          "label": "时钟方案",
          "priority": "P1",
          "key_p1": true,
          "description": "主控时钟来源与频率策略，关系到精度、启动方式和成本。",
          "examples": ["外部 8MHz 晶振", "内部 RC + USB 校准"],
          "options": ["外部 8MHz 晶振", "内部 RC", "外部有源时钟"],
          "custom_hint": "请描述时钟来源和频率配置。",
          "validation": {"min_length": 2}
        },
        {
          "key": "reset_boot",
          "label": "复位与启动",
          "priority": "P1",
          "key_p1": true,
          "description": "上电启动、下载入口和复位链路的实现方式。",
          "examples": ["独立 RESET + BOOT0", "自动下载电路"],
          "options": ["独立 RESET + BOOT0", "仅 RESET", "自动下载电路"],
          "custom_hint": "请描述 Reset/Boot 电路策略。",
          "validation": {"min_length": 2}
        },
        {
          "key": "assembly_mode",
          "label": "装配方式",
          "priority": "P1",
          "key_p1": true,
          "description": "制造装配方式，影响封装选择、调试方法和产线可行性。",
          "examples": ["SMT 贴片", "混合装配"],
          "options": ["SMT 贴片", "DIP 直插", "混合装配"],
          "custom_hint": "请描述制造装配方式。",
          "validation": {"min_length": 2}
        },
        {
          "key": "reference_design_available",
          "label": "参考设计",
          "priority": "P2",
          "description": "是否已有可复用原理图、开发板或历史项目作为参考。",
          "examples": ["STM32 Nucleo 原理图", "历史项目核心板"],
          "options": ["有官方参考设计", "有历史项目可复用", "暂无参考设计"],
          "custom_hint": "请说明参考来源，例如“STM32 Nucleo 原理图”。",
          "validation": {"min_length": 2}
        }
      ]
    }
  ]
}
