{
  "template_id": "architecture_brief_power",
  "version": "v1",
  "required_fields": [
    "board_goal",
    "power_input",
    "key_interfaces",
    "performance_constraints",
    "size_constraints",
    "cost_priority"
  ],
  "questions": [
    {
      "field": "board_goal",
      "label": "板卡目标",
      "question": "这块电源板的核心用途是什么？",
      "options": [
        "单路稳压供电",
        "多路电源管理",
        "电池充放电管理"
      ],
      "custom_hint": "请描述输出对象和应用场景，例如“给主控+传感器供电”。",
      "validation": {
        "min_length": 4
      }
    },
    {
      "field": "power_input",
      "label": "输入电源",
      "question": "输入电源规格是什么？",
      "options": [
        "USB 5V 输入",
        "12V 适配器输入",
        "24V 工业输入"
      ],
      "custom_hint": "请写明输入电压范围和保护要求。",
      "validation": {
        "min_length": 4
      }
    },
    {
      "field": "key_interfaces",
      "label": "关键接口",
      "question": "电源板需要哪些外部接口？",
      "options": [
        "DC Jack + 接线端子",
        "Type-C + 排针",
        "工业端子 + 监测接口"
      ],
      "custom_hint": "可写输入/输出连接器类型和监测信号接口。",
      "validation": {
        "min_length": 4
      }
    },
    {
      "field": "performance_constraints",
      "label": "性能约束",
      "question": "有哪些电源性能约束？",
      "options": [
        "纹波优先",
        "效率优先",
        "温升优先"
      ],
      "custom_hint": "例如“3.3V/2A，纹波<50mV，效率>90%”。",
      "validation": {
        "min_length": 4
      }
    },
    {
      "field": "size_constraints",
      "label": "尺寸约束",
      "question": "尺寸或结构限制是什么？",
      "options": [
        "无硬性限制",
        "紧凑小板",
        "可装导轨结构"
      ],
      "custom_hint": "建议提供尺寸、层数及散热空间限制。",
      "validation": {
        "min_length": 2
      }
    },
    {
      "field": "cost_priority",
      "label": "成本优先级",
      "question": "成本策略是什么？",
      "options": [
        "低成本优先",
        "平衡成本与效率",
        "高可靠优先"
      ],
      "custom_hint": "可写 BOM 目标与器件等级偏好。",
      "validation": {
        "min_length": 2
      }
    }
  ]
}
